---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-links">
      <a href="https://thetrumptracker.com" target="_blank" rel="noopener">Browse Controversies</a>
      <span class="footer-sep">·</span>
      <a href="/attacks-on-science">Science</a>
      <span class="footer-sep">·</span>
      <a href="/fascism">Fascism</a>
      <span class="footer-sep">·</span>
      <a href="/attacking-democracy">Democracy</a>
      <span class="footer-sep">·</span>
      <a href="/critics">Critics</a>
      <span class="footer-sep">·</span>
      <a href="/posts">Posts</a>
    </div>
    <p class="footer-copy">
      Data compiled through March 2026. Every claim is sourced from official government actions, congressional testimony, peer-reviewed surveys, or statements from officials and scientists.
    </p>
    <p class="footer-brand">
      <a href="https://thetrumptracker.com" target="_blank" rel="noopener">thetrumptracker.com</a> · {year}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 40px 24px;
    text-align: center;
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .footer-links {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--red);
  }

  .footer-sep {
    color: var(--faint);
    margin: 0 8px;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 1px;
    max-width: 700px;
    margin: 0 auto 12px;
    line-height: 1.6;
  }

  .footer-brand {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 1px;
  }

  .footer-brand a {
    color: var(--red);
    text-decoration: none;
  }
</style>
