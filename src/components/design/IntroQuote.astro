---
interface Props {
  quote: string;
  citation: string;
}

const { quote, citation } = Astro.props;
---

<section class="intro-section fade-up">
  <blockquote>{quote}</blockquote>
  <cite>— {citation}</cite>
</section>

<style>
  .intro-section {
    padding: 80px 24px;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-section blockquote {
    font-size: clamp(22px, 3.5vw, 34px);
    font-style: italic;
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 24px;
  }

  .intro-section cite {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--red);
    letter-spacing: 2px;
    font-style: normal;
    text-transform: uppercase;
  }
</style>
