---
interface Props {
  target: number;
  prefix?: string;
  suffix?: string;
  label: string;
  accentColor?: string;
}

const { target, prefix = '', suffix = '', label, accentColor } = Astro.props;
const borderStyle = accentColor ? `border-top-color: ${accentColor}` : '';
const numStyle = accentColor ? `color: ${accentColor}` : '';
---

<div class="stat-card fade-up" style={borderStyle}>
  <span
    class="stat-number"
    data-target={target}
    data-prefix={prefix || undefined}
    data-suffix={suffix || undefined}
    style={numStyle}
  >
    0
  </span>
  <span class="stat-label">{label}</span>
</div>

<style>
  .stat-card {
    background: var(--card);
    padding: 32px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .stat-card:hover {
    background: #222;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--red);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 72px);
    color: var(--red-bright);
    line-height: 1;
    display: block;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 8px;
    display: block;
    line-height: 1.4;
  }
</style>
