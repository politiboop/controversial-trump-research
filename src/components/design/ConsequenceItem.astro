---
interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="consequence-item fade-up">
  <div class="consequence-num">{number}</div>
  <div class="consequence-text">
    <h4>{title}</h4>
    <p>{description}</p>
  </div>
</div>

<style>
  .consequence-item {
    background: var(--card);
    padding: 28px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .consequence-num {
    font-family: var(--font-display);
    font-size: 48px;
    color: var(--red);
    line-height: 1;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .consequence-text h4 {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    color: var(--text);
  }

  .consequence-text p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }
</style>
