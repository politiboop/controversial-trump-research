---
interface Props {
  quote: string;
  /** Legacy: single HTML string for attribution (still supported) */
  attribution?: string;
  /** Structured: speaker name */
  name?: string;
  /** Structured: role/title */
  role?: string;
  /** Structured: date and/or location */
  detail?: string;
  /** Structured: additional context (rendered as normal body text, not uppercase mono) */
  context?: string;
}

const { quote, attribution, name, role, detail, context } = Astro.props;
const isStructured = !!name;
---

<div class="voice-card fade-up">
  <p class="voice-quote">{quote}</p>
  {isStructured ? (
    <div class="voice-meta">
      <div class="voice-name">{name}</div>
      {role && <div class="voice-role">{role}</div>}
      {detail && <div class="voice-detail">{detail}</div>}
      {context && <div class="voice-context">{context}</div>}
    </div>
  ) : (
    <div class="voice-attribution" set:html={attribution} />
  )}
</div>

<style>
  .voice-card {
    background: var(--card);
    padding: 32px;
    border-top: 3px solid var(--border);
    position: relative;
  }

  .voice-card::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 80px;
    color: var(--red);
    position: absolute;
    top: 10px;
    left: 24px;
    line-height: 1;
    opacity: 0.3;
  }

  .voice-quote {
    font-style: italic;
    font-size: 18px;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 16px;
    padding-top: 20px;
  }

  /* Legacy attribution (backwards compatible) */
  .voice-attribution {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--red);
    text-transform: uppercase;
    line-height: 1.6;
  }

  /* Structured attribution */
  .voice-meta {
    border-top: 1px solid var(--border);
    padding-top: 14px;
    margin-top: 4px;
  }

  .voice-name {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .voice-role {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--red);
    text-transform: uppercase;
    margin-top: 4px;
  }

  .voice-detail {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 4px;
  }

  .voice-context {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    margin-top: 10px;
    font-style: italic;
  }
</style>
