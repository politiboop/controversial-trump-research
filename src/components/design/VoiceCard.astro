---
interface Props {
  quote: string;
  attribution: string;
}

const { quote, attribution } = Astro.props;
---

<div class="voice-card fade-up">
  <p class="voice-quote">{quote}</p>
  <div class="voice-attribution" set:html={attribution} />
</div>

<style>
  .voice-card {
    background: var(--card);
    padding: 32px;
    border-top: 3px solid var(--border);
    position: relative;
  }

  .voice-card::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 80px;
    color: var(--red);
    position: absolute;
    top: 10px;
    left: 24px;
    line-height: 1;
    opacity: 0.3;
  }

  .voice-quote {
    font-style: italic;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 16px;
    padding-top: 20px;
  }

  .voice-attribution {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--red);
    text-transform: uppercase;
    line-height: 1.5;
  }
</style>
