---
interface Props {
  title: string;
  description?: string;
  linkText: string;
  linkHref: string;
}

const { title, description, linkText, linkHref } = Astro.props;
---

<section class="cta-section">
  <h2 set:html={title} />
  {description && <p>{description}</p>}
  <a class="cta-link" href={linkHref}>{linkText}</a>
</section>

<style>
  .cta-section {
    padding: 80px 24px;
    text-align: center;
    background: var(--deep);
    border-top: 1px solid var(--border);
  }

  .cta-section h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 7vw, 80px);
    color: var(--text);
    margin-bottom: 20px;
    line-height: 0.9;
  }

  .cta-section p {
    font-size: 18px;
    color: var(--muted);
    font-style: italic;
    max-width: 600px;
    margin: 0 auto 36px;
  }

  .cta-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--red);
    border: 2px solid var(--red);
    padding: 14px 36px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .cta-link:hover {
    background: var(--red);
    color: #fff;
    text-decoration: none;
  }
</style>
