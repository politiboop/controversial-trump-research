---
import ResearchLayout from '../../layouts/ResearchLayout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import PageNavigation from '../../components/navigation/PageNavigation.astro';
import CTASection from '../../components/design/CTASection.astro';
import HighlightBar from '../../components/design/HighlightBar.astro';

import categoriesData from '../../data/categories.json';

export async function getStaticPaths() {
  const postFiles = import.meta.glob('../../data/posts/*.json', { eager: true });
  const posts = Object.values(postFiles).map((mod: any) => mod.default || mod);
  posts.sort((a, b) => b.id.localeCompare(a.id)); // newest first
  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: posts[index + 1] || null,
      nextPost: posts[index - 1] || null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const categories = categoriesData.categories;
const cat = categories[post.category as keyof typeof categories];
const catColor = cat?.color || 'var(--red)';
const catIcon = cat?.icon || '';
const catTitle = cat?.title || post.category;

// Extract the post number from the id
const postNumber = post.id.replace('post-', '');

// Format date nicely
function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Format a controversy ID into a readable title
function formatControversyTitle(id: string): string {
  return id
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const shareUrl = `https://research.thetrumptracker.com/posts/${post.id}`;
const formattedDate = formatDate(post.date);
const hashtagsText = post.hashtags?.length
  ? post.hashtags.map((t: string) => `#${t}`).join(' ')
  : '';
const copyText = `${post.text}${hashtagsText ? '\n\n' + hashtagsText : ''}\n\n${shareUrl}`;
---

<ResearchLayout title={`Post #${postNumber} — The Trump Tracker`} description={post.text.slice(0, 160)}>

  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Posts', href: '/posts' },
    { label: `Post #${postNumber}` },
  ]} />

  <!-- Post Header -->
  <header class="post-header container">
    <div class="header-row">
      <span class="category-badge" style={`--badge-color: ${catColor}`}>
        <span class="category-icon">{catIcon}</span>
        <span class="category-label">{catTitle}</span>
      </span>
      <time class="post-date" datetime={post.date}>{formattedDate}</time>
    </div>
    <h1 class="post-title">Post <span class="post-number" style={`color: ${catColor}`}>#{postNumber}</span></h1>
  </header>

  <!-- Post Body -->
  <section class="post-body-section container">
    <div class="post-card" style={`--card-accent: ${catColor}`}>
      <div class="post-text">{post.text}</div>
    </div>
  </section>

  <!-- Actions Bar -->
  <div class="actions-bar container">
    <button class="action-btn" id="copy-btn" data-copy-text={copyText}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
      <span id="copy-label">Copy</span>
    </button>
    <button class="action-btn" id="share-btn" data-share-url={shareUrl} data-share-title={`Trump Tracker — Post #${postNumber}`} data-share-text={post.text.slice(0, 200)}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
      <span id="share-label">Share</span>
    </button>
  </div>

  <!-- Hashtags -->
  {post.hashtags && post.hashtags.length > 0 && (
    <section class="hashtags-section container">
      <div class="hashtags-list">
        {post.hashtags.map((tag: string) => (
          <span class="hashtag" style={`--tag-color: ${catColor}`}>#{tag}</span>
        ))}
      </div>
    </section>
  )}

  <!-- Linked Controversies -->
  {post.controversyIds && post.controversyIds.length > 0 && (
    <section class="controversies-section container">
      <div class="section-eyebrow">Backed by Evidence</div>
      <h2 class="section-title">Linked Controversies</h2>
      <p class="section-intro">
        This post references {post.controversyIds.length} documented controvers{post.controversyIds.length === 1 ? 'y' : 'ies'} — each with full sources, timelines, and severity ratings.
      </p>
      <div class="controversies-grid">
        {post.controversyIds.map((cId: string) => (
          <a
            href={`https://thetrumptracker.com/controversy?id=${cId}`}
            class="controversy-card"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="controversy-id">{cId}</div>
            <div class="controversy-title">{formatControversyTitle(cId)}</div>
            <span class="controversy-link">View on Trump Tracker &rarr;</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <HighlightBar text="Every post is backed by documented evidence. Every controversy links to official sources." />

  <PageNavigation
    prev={prevPost ? { label: `Post #${prevPost.id.replace('post-', '')}`, href: `/posts/${prevPost.id}` } : undefined}
    next={nextPost ? { label: `Post #${nextPost.id.replace('post-', '')}`, href: `/posts/${nextPost.id}` } : undefined}
  />

  <CTASection
    title="Browse All<br><span class='word-red'>Posts</span>"
    description="Read all analysis posts connecting documented controversies with patterns and context."
    linkText="All Posts &rarr;"
    linkHref="/posts"
  />

</ResearchLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Copy button
    const copyBtn = document.getElementById('copy-btn');
    const copyLabel = document.getElementById('copy-label');
    if (copyBtn && copyLabel) {
      copyBtn.addEventListener('click', async () => {
        const text = copyBtn.getAttribute('data-copy-text') || '';
        try {
          await navigator.clipboard.writeText(text);
          copyLabel.textContent = 'Copied!';
          setTimeout(() => {
            copyLabel.textContent = 'Copy';
          }, 2000);
        } catch {
          // Fallback: select from a temporary textarea
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          copyLabel.textContent = 'Copied!';
          setTimeout(() => {
            copyLabel.textContent = 'Copy';
          }, 2000);
        }
      });
    }

    // Share button
    const shareBtn = document.getElementById('share-btn');
    const shareLabel = document.getElementById('share-label');
    if (shareBtn && shareLabel) {
      shareBtn.addEventListener('click', async () => {
        const url = shareBtn.getAttribute('data-share-url') || '';
        const title = shareBtn.getAttribute('data-share-title') || '';
        const text = shareBtn.getAttribute('data-share-text') || '';

        if (navigator.share) {
          try {
            await navigator.share({ title, text, url });
          } catch {
            // User cancelled or error — do nothing
          }
        } else {
          // Fallback: copy the URL
          try {
            await navigator.clipboard.writeText(url);
            shareLabel.textContent = 'Link Copied!';
            setTimeout(() => {
              shareLabel.textContent = 'Share';
            }, 2000);
          } catch {
            shareLabel.textContent = 'Share';
          }
        }
      });
    }
  });
</script>

<style>
  /* Container */
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  /* Post Header */
  .post-header {
    padding-top: 24px;
    padding-bottom: 8px;
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--badge-color, var(--red));
    border: 1px solid var(--badge-color, var(--red));
    padding: 5px 12px;
  }

  .category-icon {
    font-size: 14px;
  }

  .category-label {
    line-height: 1;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 8vw, 72px);
    color: var(--text);
    line-height: 0.9;
    margin: 0;
  }

  .post-number {
    transition: color 0.3s;
  }

  /* Post Body */
  .post-body-section {
    padding-top: 32px;
    padding-bottom: 0;
  }

  .post-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-left: 5px solid var(--card-accent, var(--red));
    padding: 40px 40px;
  }

  .post-text {
    font-family: var(--font-body);
    font-size: 20px;
    line-height: 1.8;
    color: var(--text);
    white-space: pre-line;
  }

  /* Actions Bar */
  .actions-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 20px;
    padding-bottom: 8px;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 8px 16px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .action-btn:hover {
    color: var(--text);
    border-color: var(--text);
    background: var(--card);
  }

  .action-btn svg {
    flex-shrink: 0;
  }

  /* Hashtags */
  .hashtags-section {
    padding-top: 20px;
    padding-bottom: 40px;
  }

  .hashtags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hashtag {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--tag-color, var(--red));
    background: rgba(212, 43, 43, 0.08);
    border: 1px solid rgba(212, 43, 43, 0.2);
    padding: 5px 12px;
    transition: background 0.2s;
  }

  .hashtag:hover {
    background: rgba(212, 43, 43, 0.15);
  }

  /* Linked Controversies */
  .controversies-section {
    padding-top: 60px;
    padding-bottom: 60px;
    border-top: 1px solid var(--border);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 6vw, 56px);
    color: var(--text);
    line-height: 0.9;
    margin: 0 0 16px 0;
  }

  .section-intro {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--muted);
    font-style: italic;
    max-width: 640px;
    margin-bottom: 36px;
    line-height: 1.6;
  }

  .controversies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 12px;
  }

  .controversy-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 24px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.25s, border-color 0.25s, transform 0.25s;
  }

  .controversy-card:hover {
    background: var(--card);
    border-color: var(--amber);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .controversy-id {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--faint);
    word-break: break-all;
  }

  .controversy-title {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--text);
    line-height: 1.3;
  }

  .controversy-link {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--amber);
    margin-top: auto;
    padding-top: 8px;
    transition: letter-spacing 0.2s;
  }

  .controversy-card:hover .controversy-link {
    letter-spacing: 2.5px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .post-card {
      padding: 24px 20px;
    }

    .post-text {
      font-size: 17px;
    }

    .header-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .actions-bar {
      flex-wrap: wrap;
    }

    .controversies-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
