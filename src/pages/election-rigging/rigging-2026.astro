    description="FBI raids on election offices. Voting machines seized. Calls to 'nationalize voting.' ICE at polls. Emergency powers. This is not speculation — this is documented, real-time election rigging."
    linkText="Attacking Democracy →"
    linkHref="/attacking-democracy"
  />

  <PageNavigation
    prev={{ label: '2024', href: '/election-rigging/2024' }}
    currentIndex={2}
    totalPages={3}
  />

</ResearchLayout>
