const electionTabs = [
  { label: 'Overview', href: '/election-rigging' },
  { label: 'The Coup Attempt', href: '/election-rigging/the-coup-attempt' },
  { label: '2024', href: '/election-rigging/2024' },
  { label: 'Active Rigging 2026', href: '/election-rigging/rigging-2026' },
];

const tickerItems = [
  "700 Boxes of 2020 Ballots Seized by FBI (Jan 2026)",
  "DNI Illegally Present at FBI Raid of Election Office",
  "15 States Targeted for 'Nationalized Voting'",
  "23+ States Sued by DOJ for Voter Rolls",
  "17 Inspector Generals Fired (Ruled Unlawful)",
  "Trump Allies Push Emergency Powers for Midterms",
  "ICE at Polls Threatened — Illegal Under Federal Law",
  "Federal Judge: 'The Taking of Democracy'",
