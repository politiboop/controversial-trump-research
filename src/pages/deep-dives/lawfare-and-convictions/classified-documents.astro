  <!-- HOW OTHERS WERE TREATED -->
  <SectionDivider label="The Comparison" />
  <SectionHeader
    eyebrow="Same Crime, Different People"
    title="How Others<br>Were Treated"
    introText="Trump claims he's being singled out. Here's how the justice system treated other people who mishandled classified information."
  />

  <ConsequencesGrid eyebrow="Classified Information Cases" title="What Happened to<br>Everyone Else">
    <ConsequenceRow>
      <ConsequenceItem
