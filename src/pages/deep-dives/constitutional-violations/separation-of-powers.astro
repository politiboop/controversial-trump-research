const tickerItems = [
  "17 Inspectors General Fired in a Single Night — Violated 30-Day Notice",
  "Zero Documents Produced for 70+ Congressional Subpoenas During Impeachment",
  "DOGE: Unelected Private Citizens Given Authority Over Federal Agencies",
  "Border Wall Funding Ruled Unconstitutional — 9th Circuit",
  "GAO Found Multiple Spending Freezes Illegal",
  "TikTok Ban: Even Conservative AEI Called Nonenforcement Illegal",
  "Pendley Ran BLM Unlawfully — Court Voided His Actions",
  "Acting Officials Ruled Unconstitutional Under Appointments Clause",
  "Appropriations Clause: Only Congress Controls Spending",
  "Take Care Clause: President Must 'Faithfully Execute' the Laws",
  "Supreme Court Struck Down IEEPA Tariffs 6-3",
  "$133.5 Billion in Tariffs Collected Under Unconstitutional Authority",
  "Three Trump Appointees Ruled Against His Tariffs",
];
---

<ResearchLayout title="Separation of Powers — Constitutional Violations Deep Dive" description="17 inspectors general fired unlawfully. Congressional subpoenas ignored. DOGE. Spending freezes. The systematic erosion of checks and balances between branches of government.">

  <Breadcrumbs items={[
    { label: 'Research', href: '/' },
    { label: 'Deep Dives', href: '/deep-dives' },
    { label: 'The Constitution', href: '/deep-dives/constitutional-violations' },
    { label: 'Separation of Powers' }
  ]} />

  <Masthead
    eyebrow="Deep Dive · Checks & Balances"
    title="SEPARATION OF <span class='word-red'>POWERS</span>"
    subtitle="When the executive branch claims the authority of all three branches."
    date="Sources: Congressional Records · GAO Opinions · Federal Court Orders · Inspector General Reports · Appointments Clause Rulings"
  />

  <Ticker items={tickerItems} />

  <IntroQuote
    quote="The accumulation of all powers, legislative, executive, and judiciary, in the same hands, whether of one, a few, or many, and whether hereditary, self-appointed, or elective, may justly be pronounced the very definition of tyranny."
    citation="James Madison — Federalist No. 47, 1788"
  />

  <!-- KEY STATS -->
  <StatGrid>
    <StatCard target={17} label="Inspectors general fired in a single night — violating the 30-day notice requirement" />
    <StatCard target={0} label="Documents produced in response to 70+ congressional subpoenas during impeachment" />
    <StatCard target={70} suffix="+" label="Congressional requests for documents or testimony that were totally ignored" />
    <StatCard target={3} label="Constitutional clauses violated — Appropriations, Take Care, Appointments" />
  </StatGrid>

  <!-- INSPECTOR GENERAL FIRINGS -->
  <SectionDivider label="Chapter I" />
  <SectionHeader
    eyebrow="Chapter I · Oversight Eliminated"
    title="17 Inspectors<br>General"
    introText="Inspectors general are the government's internal watchdogs — independent officials who investigate waste, fraud, and abuse within federal agencies. Federal law requires 30 days' written notice to Congress before removing an IG. On a single night, the Trump administration fired 17 of them."
  />

  <CategoryGrid>
    <CategoryCard
      icon="🔍"
      title="What Inspectors General Do"
      body="Inspectors general are <strong>independent watchdogs</strong> created by the Inspector General Act of 1978 (passed after Watergate). They exist to:<br><br>• <strong>Investigate waste, fraud, and abuse</strong> within federal agencies<br>• <strong>Report to Congress</strong> independently of the agency they oversee<br>• <strong>Protect whistleblowers</strong> who report misconduct<br>• <strong>Audit government spending</strong> and program effectiveness<br><br>They are specifically designed to be <strong>independent of the officials they oversee</strong>."
      tag="Independent Oversight"
    />
    <CategoryCard
      icon="🌙"
      title="The Friday Night Massacre"
      body="On a single night in January 2025, the Trump administration <strong>fired 17 inspectors general</strong> across the federal government — including watchdogs at the <strong>Defense Department, State Department, CIA, and other critical agencies</strong>.<br><br>The firings violated the <strong>Inspector General Reform Act</strong>, which requires the president to give Congress <strong>30 days' written notice</strong> and a substantive explanation before removing an IG. No notice was given. No explanations were provided."
      tag="17 in One Night"
    />
    <CategoryCard
      icon="⚖️"
      title="Courts Found the Firings Unlawful"
      body="Federal courts ruled that the mass firings <strong>violated federal law</strong>. The 30-day notice requirement is not a suggestion — it is a <strong>statutory mandate</strong> designed to give Congress the opportunity to investigate whether the removal is politically motivated.<br><br>By firing all 17 simultaneously, without notice, the administration <strong>eliminated the entire oversight infrastructure</strong> of the federal government in a single action — making it impossible for Congress to exercise its review authority."
      tag="Unlawful"
    />
    <CategoryCard
      icon="🎯"
      title="Why It Matters"
      body="Without inspectors general, there is <strong>no independent oversight</strong> of how federal agencies spend taxpayer money, whether they follow the law, or whether officials engage in misconduct.<br><br>Several of the fired IGs had been <strong>actively investigating</strong> matters of public interest. Their removal sent a clear message to any future watchdog: <strong>investigate this administration and lose your job</strong>."
      tag="No Oversight"
    />
  </CategoryGrid>

  <!-- CONGRESSIONAL SUBPOENAS -->
  <SectionDivider label="Chapter II" />
  <SectionHeader
    eyebrow="Chapter II · Defying Congress"
    title="Total<br>Stonewalling"
    introText="During the first impeachment inquiry, the Trump administration adopted an unprecedented position: total, categorical refusal to comply with any congressional subpoena. Not selective compliance. Not executive privilege claims for specific documents. Zero cooperation."
  />

  <ColoredSection background="#0a0c12" borderColor="var(--red)">
    <AlertBanner icon="📊" title="The Scope of Defiance" variant="red">
      <p style="font-size: 16px; color: var(--muted); line-height: 1.7;">The White House Counsel sent a letter declaring that the administration would <strong style="color: var(--text);">not cooperate in any way</strong> with the impeachment inquiry. The result: <strong style="color: var(--text);">zero documents produced</strong> in response to over <strong style="color: var(--text);">70 congressional requests</strong>. Key witnesses were ordered not to testify. This was not executive privilege — it was a <strong style="color: var(--text);">blanket refusal</strong> to recognize Congress's constitutional oversight authority.</p>
    </AlertBanner>
  </ColoredSection>

  <CategoryGrid>
    <CategoryCard
      icon="📄"
      title="The White House Letter"
      body="White House Counsel Pat Cipollone sent an 8-page letter to Congress declaring that the administration would <strong>not participate in the impeachment inquiry</strong> in any way.<br><br>The letter did not assert executive privilege for specific documents or communications. Instead, it challenged the <strong>legitimacy of the entire inquiry</strong> — a position with no basis in the Constitution, which grants the House the <em>&quot;sole Power of Impeachment.&quot;</em>"
      tag="Blanket Refusal"
    />
    <CategoryCard
      icon="🚫"
      title="Witnesses Blocked"
      body="Key administration officials were <strong>ordered not to testify</strong> before Congress:<br><br>• <strong>Don McGahn</strong> (White House Counsel) — blocked<br>• <strong>Mick Mulvaney</strong> (Chief of Staff) — blocked<br>• <strong>Mike Pompeo</strong> (Secretary of State) — blocked<br>• <strong>John Bolton</strong> (National Security Advisor) — refused to testify without a subpoena, then sued to avoid one<br><br>Some officials — like <strong>Fiona Hill, Alexander Vindman, and Marie Yovanovitch</strong> — testified anyway, defying the White House directive."
      tag="Key Officials Blocked"
    />
  </CategoryGrid>

  <!-- DOGE AND APPROPRIATIONS -->
  <SectionDivider label="Chapter III" />
  <SectionHeader
    eyebrow="Chapter III · The Power of the Purse"
    title="DOGE &amp; the<br>Appropriations Clause"
    introText="The Constitution vests the 'power of the purse' exclusively in Congress. Article I, Section 9 states: 'No Money shall be drawn from the Treasury, but in Consequence of Appropriations made by Law.' The Trump administration's actions challenged this foundational principle in multiple ways."
  />

  <CategoryGrid>
    <CategoryCard
      icon="🏢"
      title="DOGE: Unelected Authority"
      body="The Department of Government Efficiency (DOGE) — led by <strong>unelected private citizens</strong> — was given sweeping authority over federal agencies, including access to sensitive government systems and the power to recommend (and effectively direct) mass personnel changes.<br><br>The constitutional question is fundamental: can the president delegate <strong>government authority</strong> to private individuals who have not been confirmed by the Senate, are not subject to congressional oversight, and have <strong>no statutory authorization</strong> for their role?"
      tag="No Senate Confirmation"
    />
    <CategoryCard
      icon="💰"
      title="Spending Freezes"
      body="The administration imposed <strong>broad freezes on congressionally appropriated funds</strong> — money that Congress had already allocated for specific purposes.<br><br>The <strong>Government Accountability Office (GAO)</strong> — Congress's nonpartisan investigative arm — found that <strong>multiple spending freezes were illegal</strong>, violating the Impoundment Control Act of 1974. That law was passed after Nixon's abuses and requires the president to spend money Congress appropriates unless he follows specific procedures."
      tag="GAO: Illegal"
    />
    <CategoryCard
      icon="🧱"
      title="Border Wall Funding"
      body="When Congress refused to fund the border wall, Trump declared a <strong>national emergency</strong> and redirected military construction funds to wall construction.<br><br>The <strong>9th Circuit Court of Appeals</strong> ruled this unconstitutional — finding that the president cannot override Congress's spending decisions by declaring an emergency. The <strong>Appropriations Clause</strong> gives Congress, not the president, the exclusive power to decide how federal money is spent."
      tag="9th Circuit: Unconstitutional"
    />
    <CategoryCard
      icon="📱"
      title="The Take Care Clause"
      body="Article II requires the president to <strong>&quot;take Care that the Laws be faithfully executed.&quot;</strong> Yet the administration <strong>refused to enforce the TikTok ban</strong> — a law passed by Congress and signed by Biden.<br><br>Even the <strong>American Enterprise Institute (AEI)</strong>, a conservative think tank, called the nonenforcement illegal. The president's duty is to enforce laws passed by Congress — even laws he disagrees with. Selective nonenforcement is not a presidential power."
      tag="Even AEI Objected"
    />
  </CategoryGrid>

  <!-- APPOINTMENTS CLAUSE -->
  <SectionDivider label="Chapter IV" />
  <SectionHeader
    eyebrow="Chapter IV · The Appointments Clause"
    title="Unlawful<br>Appointments"
    introText="The Constitution requires 'principal officers' of the United States to be nominated by the president and confirmed by the Senate. The Trump administration repeatedly installed officials without proper appointment — and courts repeatedly struck down their actions."
  />

  <CategoryGrid>
    <CategoryCard
      icon="👤"
      title="William Perry Pendley — BLM"
      body="William Perry Pendley served as <strong>acting director of the Bureau of Land Management</strong> for over a year without Senate confirmation and without proper designation under the Federal Vacancies Reform Act.<br><br>A federal court ruled his appointment <strong>unlawful</strong> and voided actions he had taken — including decisions affecting millions of acres of public land. The court found the administration had used the &quot;acting&quot; designation to <strong>circumvent the Senate's constitutional role</strong>."
      tag="Actions Voided"
    />
    <CategoryCard
      icon="👤"
      title="Michael Pack — USAGM"
      body="Michael Pack's installation as head of the <strong>U.S. Agency for Global Media</strong> — which oversees Voice of America and other international broadcasters — was <strong>ruled unconstitutional</strong>.<br><br>Pack immediately fired the heads of the agency's networks, installed loyalists, and began <strong>investigating journalists</strong> for perceived bias against Trump. A federal court found his actions violated the <strong>statutory independence</strong> of the broadcasters he was supposed to oversee."
      tag="Unconstitutional"
    />
  </CategoryGrid>

  <!-- UNCONSTITUTIONAL TARIFFS -->
  <SectionDivider label="Chapter V" />
  <SectionHeader
    eyebrow="Chapter V · The Taxing Power"
    title="Unconstitutional<br>Tariffs"
    introText="Article I, Section 8 grants Congress the power 'To lay and collect Taxes, Duties, Imposts and Excises' and to 'regulate Commerce with foreign Nations.' The Trump administration imposed sweeping tariffs by declaring national emergencies under IEEPA — bypassing Congress entirely. The Supreme Court struck them down 6-3."
  />

  <VoicesSection
    eyebrow="The Supreme Court"
    title="The Court<br>Rules 6-3"
    introText="In Learning Resources, Inc. v. Trump (February 2026), the Supreme Court ruled that IEEPA does not authorize the president to impose tariffs — with three of Trump's own appointees in the majority."
  >
    <VoiceCard
      quote="Based on two words separated by 16 others in... IEEPA — 'regulate' and 'importation' — the President asserts the independent power to impose tariffs on imports from any country, of any product, at any rate, for any amount of time."
      name="Chief Justice John Roberts"
      role="Majority Opinion"
      detail="Learning Resources, Inc. v. Trump · February 20, 2026"
      context="Roberts was joined by Gorsuch, Barrett, Sotomayor, Kagan, and Jackson. Three Trump appointees ruled against the administration."
    />
    <VoiceCard
      quote="IEEPA contains no reference to tariffs or duties. Until now no President has read IEEPA to confer such power."
      name="Chief Justice John Roberts"
      role="Majority Opinion"
      detail="Learning Resources, Inc. v. Trump · February 20, 2026"
      context="The Court noted that IEEPA was enacted in 1977, and no president in nearly 50 years had ever claimed it authorized tariffs."
    />
  </VoicesSection>

  <CategoryGrid>
    <CategoryCard
      icon="💰"
      title="The Tariffs Imposed"
      body="Trump invoked IEEPA by declaring national emergencies — first over fentanyl trafficking, then over the trade deficit — to impose sweeping tariffs without congressional authorization:<br><br>• <strong>Canada:</strong> 25% (10% on energy)<br>• <strong>Mexico:</strong> 25%<br>• <strong>China:</strong> Escalated to 145%<br>• <strong>&quot;Liberation Day&quot; (April 2, 2025):</strong> Baseline 10% on nearly all countries, with higher rates on 57 countries<br><br>By December 2025, CBP had collected approximately <strong>$133.5 billion</strong> in tariffs under IEEPA authority."
      tag="$133.5 Billion Collected"
    />
    <CategoryCard
      icon="⚖️"
      title="Every Court Agreed"
      body="The tariffs were struck down at <strong>every level of the judiciary</strong>:<br><br>• <strong>Court of International Trade</strong> (May 2025): Unanimously ruled IEEPA tariffs illegal, calling the legal basis <em>&quot;a wafer-thin reed on which to rest such sweeping power&quot;</em><br>• <strong>Federal Circuit Court of Appeals</strong> (August 2025): Upheld the CIT ruling<br>• <strong>Supreme Court</strong> (February 2026): Ruled 6-3 that IEEPA does not authorize tariffs<br><br>Three Trump appointees — <strong>Gorsuch, Barrett,</strong> and <strong>Roberts</strong> (appointed by Bush but Chief Justice) — joined the majority."
      tag="Struck Down at Every Level"
    />
    <CategoryCard
      icon="📜"
      title="The Constitutional Principle"
      body="The core constitutional issue is straightforward: <strong>tariffs are taxes, and only Congress can impose taxes.</strong><br><br>The Court applied the <strong>major questions doctrine</strong>: actions of &quot;vast economic and political significance&quot; require clear congressional authorization. IEEPA's grant of authority to &quot;regulate... importation&quot; did not clearly authorize taxation — and the Court held that <strong>no president in IEEPA's nearly 50-year history</strong> had ever read it to confer tariff power.<br><br>The Court also noted that reading &quot;regulate&quot; to include taxation would implicitly authorize <strong>export taxes</strong> — which are unconstitutional under Article I, Section 9."
      tag="Major Questions Doctrine"
    />
    <CategoryCard
      icon="🚨"
      title="The Scale of the Overreach"
      body="The Court's holding captured the scope of what the administration claimed:<br><br><em>&quot;The President asserts the extraordinary power to unilaterally impose tariffs of <strong>unlimited amount, duration, and scope</strong>. In light of the breadth, history, and constitutional context of that asserted authority, he must identify clear congressional authorization to exercise it. IEEPA's grant of authority to 'regulate... importation' falls short.&quot;</em><br><br>The administration had claimed the power to impose <strong>any tariff, on any product, from any country, for any length of time</strong> — without a vote in Congress."
      tag="Unlimited, Unilateral Power"
    />
  </CategoryGrid>

  <!-- TALKING POINTS -->
  <SectionDivider label="Talking Points" />
  <SectionHeader
    eyebrow="Claims vs. Record"
    title="Testing the<br>Talking Points"
    introText="The administration and its supporters offer specific justifications for these actions. Here is each claim, tested against the record."
  />

  <section class="tp-section">
    <div class="tp-inner">
      <div class="tp-claim">
        <div class="tp-number">01</div>
        <div class="tp-label">The Talking Point</div>
        <h3 class="tp-text">"The president has the right to fire anyone in the executive branch."</h3>
      </div>
      <div class="tp-facts">
        <div class="tp-facts-label">The Record</div>
        <div class="tp-facts-content">
          <p><strong>Congress has the constitutional authority to set conditions on removal.</strong> The Inspector General Reform Act requires 30 days' notice to Congress before removing an IG. This is not a suggestion — it is a law passed by Congress under its Article I powers.</p>
          <p>The Supreme Court has repeatedly upheld Congress's authority to protect certain officials from at-will removal — precisely to ensure that <strong>independent oversight</strong> remains possible. The question is not whether the president can fire IGs. It's whether he can do so <strong>without following the law</strong>.</p>
          <p>Firing 17 inspectors general in one night, with no notice and no explanation, was not an exercise of presidential authority. It was an <strong>evasion of congressional oversight</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="tp-section">
    <div class="tp-inner">
      <div class="tp-claim">
        <div class="tp-number">02</div>
        <div class="tp-label">The Talking Point</div>
        <h3 class="tp-text">"DOGE is just making government more efficient — what's wrong with that?"</h3>
      </div>
      <div class="tp-facts">
        <div class="tp-facts-label">The Record</div>
        <div class="tp-facts-content">
          <p><strong>The constitutional issue is not efficiency — it's authority.</strong> The Constitution requires that principal officers exercising significant government authority be <strong>nominated by the president and confirmed by the Senate</strong>.</p>
          <p>DOGE's leadership consisted of <strong>unelected private citizens</strong> who were given access to sensitive government systems, directed mass personnel changes, and made decisions affecting billions of dollars in government spending — all without Senate confirmation, statutory authorization, or meaningful congressional oversight.</p>
          <p>If efficiency justified bypassing constitutional requirements, then any president could delegate government authority to private individuals indefinitely. The Founders designed the confirmation process specifically to prevent this concentration of unchecked power.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="tp-section">
    <div class="tp-inner">
      <div class="tp-claim">
        <div class="tp-number">03</div>
        <div class="tp-label">The Talking Point</div>
        <h3 class="tp-text">"Congress wastes money — the president should be able to cut spending."</h3>
      </div>
      <div class="tp-facts">
        <div class="tp-facts-label">The Record</div>
        <div class="tp-facts-content">
          <p><strong>The Constitution gives the power of the purse exclusively to Congress — not the president.</strong> Article I, Section 9: "No Money shall be drawn from the Treasury, but in Consequence of Appropriations made by Law."</p>
          <p>The Impoundment Control Act of 1974 was passed specifically because <strong>Nixon tried the same thing</strong> — impounding funds Congress had appropriated. Congress determined that the president may not unilaterally refuse to spend money that Congress has directed be spent.</p>
          <p>The GAO — a <strong>nonpartisan congressional agency</strong> — found that the administration's spending freezes were illegal. The president has the authority to propose budget cuts to Congress. He does not have the authority to <strong>override Congress's decisions unilaterally</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="tp-section tp-section-last">
    <div class="tp-inner">
      <div class="tp-claim">
        <div class="tp-number">04</div>
        <div class="tp-label">The Talking Point</div>
        <h3 class="tp-text">"Tariffs are a negotiating tool — the president needs flexibility on trade."</h3>
      </div>
      <div class="tp-facts">
        <div class="tp-facts-label">The Record</div>
        <div class="tp-facts-content">
          <p><strong>The Supreme Court ruled 6-3 that these tariffs were unconstitutional.</strong> The majority — including three of Trump's own appointees — held that IEEPA does not authorize the president to impose tariffs. The power to "lay and collect Taxes, Duties, Imposts and Excises" belongs to Congress under Article I, Section 8.</p>
          <p>No president in IEEPA's nearly <strong>50-year history</strong> had ever claimed it authorized tariffs. The administration asserted the power to impose tariffs of <strong>unlimited amount, duration, and scope</strong> on any product from any country — without a single vote in Congress. The Court applied the major questions doctrine: actions of "vast economic and political significance" require clear congressional authorization.</p>
          <p>Congress has delegated specific, limited tariff authority to the president through other statutes (Section 201, Section 301, Section 232). Those statutes include guardrails: investigations, time limits, congressional review. Using IEEPA to bypass those guardrails was the constitutional violation — not the concept of tariffs itself.</p>
        </div>
      </div>
    </div>
  </section>

