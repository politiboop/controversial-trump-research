      margin-bottom: 0;
    }
  </style>

  <HighlightBar text="One court held a full trial and found Trump engaged in insurrection. The Supreme Court said only Congress could act on it. 57 senators voted to convict — including 7 Republicans. McConnell called him 'practically and morally responsible.' The facts were never disputed." />

  <CTASection
    title="The Facts Were<br>Never Overturned."
    description="A court found insurrection after a full trial. The Supreme Court reversed on procedure. 57 senators voted guilty. The only question left is whether the 14th Amendment's disqualification clause will ever be enforced."
    linkText="← Back to Constitutional Violations"
    linkHref="/deep-dives/constitutional-violations"
  />

</ResearchLayout>
