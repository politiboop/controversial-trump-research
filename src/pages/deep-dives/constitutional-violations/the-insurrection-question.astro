      font-family: var(--font-display);
      font-size: clamp(24px, 3.5vw, 40px);
      color: var(--text);
      line-height: 1.1;
      font-style: italic;
    }

    .tp-facts {
      border-left: 3px solid var(--blue);
      padding-left: 24px;
    }

    .tp-facts-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 3px;
      color: var(--blue-bright);
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    .tp-facts-content {
      font-family: var(--font-body);
      font-size: 16px;
      color: var(--muted);
