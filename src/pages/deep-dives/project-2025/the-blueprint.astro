const tickerItems = [
  "920 Pages · 30 Chapters · 40 Primary Authors",
  "Published April 2023 — Earliest-Ever Mandate for Leadership",
  "Personnel Database: 20,000 Vetted Conservative Recruits",
  "180-Day Playbook for Every Federal Agency",
