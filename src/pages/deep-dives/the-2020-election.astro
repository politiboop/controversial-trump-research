<ResearchLayout title="The 2020 Election — Deep Dive" description="The complete documented story of the 2020 election — how every fraud claim was debunked, every lawsuit failed, and what Trump actually did to overturn the results.">

  <Breadcrumbs items={[
    { label: 'Research', href: '/' },
    { label: 'Deep Dives', href: '/deep-dives' },
