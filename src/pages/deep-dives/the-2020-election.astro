  >
    <VoiceCard
      quote="One might expect that when seeking such a startling outcome, a plaintiff would come formidably armed with compelling legal arguments and factual proof of rampant corruption. That has not happened. This Court has been presented with strained legal arguments without merit and speculative accusations, unsupported by evidence."
      name="Judge Matthew Brann"
      role="George W. Bush Appointee"
      detail="Trump v. Boockvar · Dismissed with prejudice · November 21, 2020"
    />
    <VoiceCard
      quote="Voters, not lawyers, choose the President. Ballots, not briefs, decide elections."
      name="Judge Stephanos Bibas"
