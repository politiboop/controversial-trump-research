    />
    <VoiceCard
      quote="This is not a fraud case. We are not alleging fraud. We are not saying anyone is trying to steal the election."
      name="Kory Langhofer"
      role="Trump Campaign Attorney"
      detail="Arizona Court · November 2020"
    />
    <VoiceCard
      quote="Your Honor, accusing people of fraud is a pretty big step."
      name="Jonathan S. Goldstein"
      role="Trump Campaign Attorney"
      detail="Montgomery County, Pennsylvania"
      context="When the judge asked directly if the campaign was alleging fraud."
    />
    <VoiceCard
