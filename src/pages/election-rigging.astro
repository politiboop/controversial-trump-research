---
import ResearchLayout from '../layouts/ResearchLayout.astro';
import Breadcrumbs from '../components/navigation/Breadcrumbs.astro';
import Masthead from '../components/design/Masthead.astro';
import Ticker from '../components/design/Ticker.astro';
import IntroQuote from '../components/design/IntroQuote.astro';
import HighlightBar from '../components/design/HighlightBar.astro';
import StatGrid from '../components/design/StatGrid.astro';
import StatCard from '../components/design/StatCard.astro';
import SectionHeader from '../components/design/SectionHeader.astro';
import SectionDivider from '../components/design/SectionDivider.astro';
import CategoryGrid from '../components/design/CategoryGrid.astro';
import CategoryCard from '../components/design/CategoryCard.astro';
import TimelineSection from '../components/design/TimelineSection.astro';
import TimelineItem from '../components/design/TimelineItem.astro';
import VoicesSection from '../components/design/VoicesSection.astro';
import VoiceCard from '../components/design/VoiceCard.astro';
import ConsequencesGrid from '../components/design/ConsequencesGrid.astro';
import ConsequenceRow from '../components/design/ConsequenceRow.astro';
import ConsequenceItem from '../components/design/ConsequenceItem.astro';
import AlertBanner from '../components/design/AlertBanner.astro';
import ColoredSection from '../components/design/ColoredSection.astro';
import CTASection from '../components/design/CTASection.astro';

const tickerItems = [
  "91 Criminal Charges Filed (Election-Related Conduct)",
  "60+ Court Cases Rejected Trump's Fraud Claims",
  "7 States Where Trump Organized Fake Electors",
  "700 Boxes of 2020 Ballots Seized by FBI (Jan 2026)",
  "17 Inspector Generals Fired (Ruled Unlawful)",
  "15 States Targeted for 'Nationalized Voting'",
  "23+ States Sued by DOJ for Voter Rolls",
  "DNI Illegally Present at FBI Raid of Election Office",
];
---

<ResearchLayout title="Election Rigging: A Documented Pattern" description="Comprehensive documentation of Trump's attempts to overturn, control, and rig elections - from the 2020 coup attempt to the 2026 midterm interference happening now.">

  <Breadcrumbs items={[{label: 'Research', href: '/'}, {label: 'Election Rigging'}]} />

  <!-- ACTIVE RIGGING ALERT -->
  <ColoredSection background="#1a0505" borderColor="var(--red)">
    <AlertBanner icon="🚨" title="ACTIVE: Trump Rigging 2026 Midterm Elections" variant="red">
      <p style="font-size: 15px; color: var(--muted); line-height: 1.8; margin-bottom: 12px;"><strong style="color: var(--text);">Trump is actively attempting to rig the 2026 midterm elections through:</strong></p>
      <ul style="margin-left: 1.2rem; margin-bottom: 12px;">
        <li><strong style="color: var(--text);">Conditional acceptance:</strong> Will only accept 2026 midterm results &quot;if they are honest&quot; - if not, &quot;something else has to happen&quot;</li>
        <li><strong style="color: var(--text);">Voter intimidation:</strong> Bannon calls for ICE to &quot;surround the polls&quot;; White House refuses to rule it out (illegal under federal law)</li>
        <li><strong style="color: var(--text);">Emergency powers:</strong> Trump allies pushing to invoke emergency powers ahead of midterms — send federal agents to polls, seize state election infrastructure, override state laws (March 2026)</li>
        <li><strong style="color: var(--text);">Seizing voting machines:</strong> Gabbard's DNI illegally seized Puerto Rico machines (May 2025); FBI raided Georgia and seized 700 boxes of 2020 ballots (Jan 2026)</li>
        <li><strong style="color: var(--text);">Gabbard coordination:</strong> DNI personally called Trump during Georgia raid, illegally coordinated both operations</li>
        <li><strong style="color: var(--text);">Unconstitutional takeover:</strong> Publicly called to &quot;nationalize voting&quot; in 15 states (federal takeover of state elections)</li>
        <li><strong style="color: var(--text);">Bypass Congress:</strong> Threatened executive order to mandate voter ID &quot;whether approved by Congress or not&quot; - a federal judge already struck down his previous election EO as unconstitutional</li>
        <li><strong style="color: var(--text);">Installing loyalists</strong> at FBI and DOJ to coordinate raids and intimidation</li>
        <li><strong style="color: var(--text);">Purging oversight:</strong> Fired 17 IGs (ruled unlawful) to remove accountability mechanisms</li>
      </ul>
      <p style="font-size: 15px; color: var(--red-bright); font-weight: 700; margin: 0;"><strong>This is election rigging happening in real-time.</strong></p>
    </AlertBanner>
  </ColoredSection>

  <Masthead
    eyebrow="Documented Pattern · Three Elections · Escalating Threat"
    title="ELECTION RIGGING"
    titleHighlight="RIGGING"
    subtitle="From Attempted Coup to Federal Takeover: Trump's War on Democratic Elections"
    date="Last Updated: March 4, 2026"
  />

  <Ticker items={tickerItems} />

  <IntroQuote
    quote="This page documents proven actions, direct statements, and ongoing attempts by Donald Trump to overturn, control, and rig American elections. Everything here is sourced from court documents, criminal indictments, witness testimony, recordings, or Trump's own words. This is not speculation. This is a factual timeline showing an escalating pattern across three elections."
    citation="Evidence-Based Documentation"
  />

  <!-- KEY STATISTICS -->
  <StatGrid>
    <StatCard target={91} label="Criminal charges filed (election-related conduct)" />
    <StatCard target={60} suffix="+" label="Court cases rejected Trump's fraud claims" />
    <StatCard target={7} label="States where Trump organized fake electors" />
    <StatCard target={700} label="Boxes of 2020 ballots seized by FBI (Jan 2026)" />
    <StatCard target={17} label="Inspector Generals fired (ruled unlawful)" />
    <StatCard target={15} label="States targeted for &quot;nationalized voting&quot;" />
  </StatGrid>

  <!-- ERA OVERVIEW -->
  <SectionDivider label="The Escalation" />
  <SectionHeader
    eyebrow="Three Elections · One Pattern"
    title="An Escalating<br>Pattern"
    introText="From contesting results after losing, to pre-emptive fraud claims, to seizing control of elections before votes are cast."
  />

  <CategoryGrid>
    <CategoryCard
      icon="🗳️"
      title="2020: The Coup Attempt"
      body="Tried to overturn election after losing. Fake electors in 7 states. Pressured Pence. Incited January 6 attack. <strong>91 criminal charges filed.</strong>"
      tag="Attempted Coup"
      variant="red"
    />
    <CategoryCard
      icon="⚠️"
      title="2024: Unresolved Questions"
      body="Pre-emptive fraud claims throughout campaign. Won election — fraud claims stopped immediately. <strong>No accountability for 2020 emboldened escalation.</strong>"
      tag="No Consequences"
      variant="amber"
    />
    <CategoryCard
      icon="🚨"
      title="2026: Active Rigging"
      body="Rigging elections <strong>before votes are cast</strong>. FBI raids election offices. DNI seizes voting machines. Calls to &quot;nationalize voting.&quot; Federal takeover of state elections."
      tag="Happening Now"
      variant="red"
    />
  </CategoryGrid>

  <!-- ===== 2020: THE COUP ATTEMPT ===== -->
  <SectionDivider label="2020" />
  <SectionHeader
    eyebrow="The Coup Attempt"
    title="2020: Overturning<br>the Election"
    introText="After losing the 2020 election, Trump attempted to overturn the results through a multi-pronged effort involving fake electors, pressure on state officials, attempted corruption of the Justice Department, and ultimately violence at the Capitol. Trump has been criminally indicted for these actions with extensive evidence documented in court filings."
  />

  <!-- What Trump Said - 2020 -->
  <VoicesSection
    eyebrow="2020 · What Trump Said"
    title="Trump's Own<br>Words"
    introText="Trump's rhetoric laying groundwork for coup attempt and inciting violence"
  >
    <VoiceCard
      quote="Frankly, we did win this election... This is a fraud on the American public. This is an embarrassment to our country."
      attribution="Donald Trump — November 3-4, 2020 (Election Night) · Declared victory while millions of votes remained uncounted. Began false &quot;stolen election&quot; narrative. · <a href='https://www.cnn.com/2020/11/04/politics/trump-election-night-speech/index.html' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: CNN</a>"
    />
    <VoiceCard
      quote="So look. All I want to do is this. I just want to find 11,780 votes, which is one more than we have. Because we won the state."
      attribution="Donald Trump — January 2, 2021 · Pressuring Georgia Secretary of State Brad Raffensperger to &quot;find&quot; votes. Full audio recording confirms pressure campaign. · <a href='https://www.washingtonpost.com/politics/trump-raffensperger-call-georgia-vote/2021/01/03/d45acb92-4dc4-11eb-bda4-615aaefd0555_story.html' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: Washington Post (full recording)</a>"
    />
    <VoiceCard
      quote="We fight like hell. And if you don't fight like hell, you're not going to have a country anymore. We're going to walk down to the Capitol."
      attribution="Donald Trump — January 6, 2021 · Speech to crowd before Capitol attack. Directed mob to Capitol to stop electoral certification. · <a href='https://www.npr.org/2021/02/10/966396848/read-trumps-jan-6-speech-a-key-part-of-impeachment-trial' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: NPR (full transcript)</a>"
    />
    <VoiceCard
      quote="Mike Pence didn't have the courage to do what should have been done to protect our Country and our Constitution."
      attribution="Donald Trump — January 6, 2021 (During Attack) · Attacked Pence on Twitter while mob was storming Capitol. Rioters chanted &quot;Hang Mike Pence&quot; after this tweet. Pence evacuated by Secret Service. · <a href='https://www.politico.com/news/2021/01/06/trump-tweet-pence-rioters-455285' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: Politico</a>"
    />
    <VoiceCard
      quote="We love you, you're very special... I know how you feel. But go home and go home in peace."
      attribution="Donald Trump — January 6, 2021 (Video to Rioters) · After 187 minutes of refusing to call off the mob, Trump finally released video praising the rioters who attacked the Capitol. · <a href='https://www.bbc.com/news/world-us-canada-55580466' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: BBC News</a>"
    />
  </VoicesSection>

  <!-- What Trump Did - 2020 -->
  <TimelineSection title="What Trump<br>Did" subtitle="Concrete actions to overturn 2020 election">
    <TimelineItem
      date="NOV-DEC 2020"
      badge="SEVERE"
      badgeType="catastrophic"
      title="The Fake Electors Scheme"
      description="Trump and co-conspirators organized fake slates of electors in 7 states Biden won: Arizona, Georgia, Michigan, Nevada, New Mexico, Pennsylvania, and Wisconsin. False elector certificates were created and signed. Fake electors met in state capitols on December 14, 2020. Certificates sent to Congress. Text messages, emails, and testimony document the coordination. Legal status: Trump and 18 others indicted in Georgia RICO case. Multiple fake electors have pleaded guilty."
    />
    <TimelineItem
      date="DEC 2020-JAN 2021"
      badge="SEVERE"
      badgeType="catastrophic"
      title="Pressure Campaign on Vice President Mike Pence"
      description="Trump pressured Pence to refuse to certify electoral votes on January 6. Trump told Pence 'You're too honest' when Pence refused. Tweeted attack on Pence while mob was storming Capitol. Rioters chanted 'Hang Mike Pence.' Pence evacuated by Secret Service. Trump showed no concern for Pence's safety. Central to Jack Smith's federal indictment."
    />
    <TimelineItem
      date="JAN 6, 2021"
      badge="SEVERE"
      badgeType="catastrophic"
      title="The Attack on the Capitol"
      description="Trump directed mob to Capitol. Mob breached Capitol for first time since 1814. 5 people died, 140+ police officers injured. Members of Congress evacuated. Trump watched on TV for 187 minutes, refused to call off mob. Eventually told rioters 'We love you, you're very special.' Impeached for 'incitement of insurrection' (10 Republicans voted to impeach). Criminally indicted by Jack Smith."
    />
    <TimelineItem
      date="POST-ELECTION 2020"
      title="Filed 60+ Lawsuits to Overturn Election"
      description="Trump and allies filed over 60 lawsuits in state and federal courts challenging election results. Result: Lost virtually every case, including before Trump-appointed judges."
    />
  </TimelineSection>

  <!-- Legal/Court Response - 2020 -->
  <SectionDivider label="Legal Response" />
  <SectionHeader
    eyebrow="2020 · Courts &amp; Law"
    title="Legal<br>Accountability"
    introText="How courts and the legal system responded to Trump's coup attempt"
  />

  <StatGrid>
    <StatCard target={91} label="Criminal Charges Filed" />
    <StatCard target={4} label="Federal Felony Counts (Jack Smith)" />
    <StatCard target={13} label="Felony Counts (Georgia RICO)" />
    <StatCard target={60} suffix="+" label="Election Lawsuits Rejected" />
    <StatCard target={2} label="Impeachments" />
    <StatCard target={845} label="Pages in J6 Committee Report" />
  </StatGrid>

  <TimelineSection title="Court &amp;<br>Legal Actions" subtitle="2020 legal proceedings">
    <TimelineItem
      date="AUG 2023"
      badge="INDICTED"
      badgeType="catastrophic"
      title="Federal Indictment by Special Counsel Jack Smith"
      description="4 felony counts: Conspiracy to defraud the United States, conspiracy to obstruct an official proceeding, obstruction of and attempt to obstruct an official proceeding, conspiracy against rights. Indictment details fake elector scheme, pressure on Pence, January 6. Status: Trump used presidential powers to have case dismissed after winning 2024 election."
    />
    <TimelineItem
      date="AUG 2023"
      badge="INDICTED"
      badgeType="catastrophic"
      title="Georgia RICO Indictment"
      description="13 felony counts in Georgia for election interference. 18 co-defendants indicted in conspiracy. Includes 'Find 11,780 votes' phone call and fake electors scheme. Multiple defendants have pleaded guilty and are cooperating. Status: Case ongoing but delayed."
    />
    <TimelineItem
      date="JAN 2021"
      badge="IMPEACHED"
      badgeType="catastrophic"
      title="Second Impeachment"
      description="Impeached by House for 'incitement of insurrection.' 232-197 vote (10 Republicans voted yes). Acquitted by Senate 57-43 (fell short of 67 needed). 7 Republican senators voted to convict. Mitch McConnell: 'There is no question that President Trump is practically and morally responsible for provoking the events of that day.'"
    />
    <TimelineItem
      date="DEC 2022"
      title="January 6 Committee Findings"
      description="845-page final report with extensive evidence. Testimony from Trump's own staff and officials. Documented Trump's 187 minutes of inaction during attack. Criminal referrals to DOJ. Committee conclusion: Trump engaged in 'multi-part conspiracy' to overturn election."
    />
    <TimelineItem
      date="NOV-DEC 2020"
      title="60+ Court Cases: Trump Lost Virtually Every One"
      description="Notable judicial quotes — Pennsylvania federal judge: 'Charges require specific allegations and proof. We have neither here.' Wisconsin federal judge: 'This Court has allowed plaintiff the chance to make his case and he has lost on the merits.' Federal appeals court: 'Free, fair elections are the lifeblood of our democracy. Charges of unfairness are serious. But calling an election unfair does not make it so.'"
    />
  </TimelineSection>

  <!-- Expert Assessment - 2020 -->
  <VoicesSection
    eyebrow="2020 · Expert Assessment"
    title="What Experts<br>Said"
    introText="What experts said about Trump's 2020 coup attempt"
  >
    <VoiceCard
      quote="The 2020 election in Georgia was not stolen. We counted the votes three times. Every allegation has been investigated and disproven. These continued attacks undermine confidence in our democratic process."
      attribution="Brad Raffensperger — Georgia Secretary of State (Republican) · November 2020 and repeatedly since · Republican election official in swing state, directly contradicts Trump's claims"
    />
    <VoiceCard
      quote="The November 3rd election was the most secure in American history... There is no evidence that any voting system deleted or lost votes, changed votes, or was in any way compromised."
      attribution="Chris Krebs — Former Director of CISA, Fired by Trump · November 2020 · Trump's own cybersecurity chief confirmed election integrity, was fired for telling the truth"
    />
    <VoiceCard
      quote="This was an attempted coup. Trump tried to overturn a democratic election through pressure, fraud, and ultimately violence. It's the most serious threat to American democracy since the Civil War."
      attribution="Laurence Tribe — Harvard Law Professor, Constitutional Scholar · January 2021"
    />
    <VoiceCard
      quote="We realized from the beginning it was just bullshit... There was never an indication of interest in what the actual facts were."
      attribution="William Barr — Former Attorney General under Trump · June 2022 (January 6 Committee testimony) · Trump's own AG confirmed fraud claims were false"
    />
    <VoiceCard
      quote="This is a Reichstag moment. The gospel of the F&uuml;hrer."
      attribution="Mark Milley — Former Chairman of the Joint Chiefs of Staff · January 6, 2021 (reported in Bob Woodward's &quot;Peril&quot;) · Highest-ranking military officer compared January 6 to Nazi tactics"
    />
    <VoiceCard
      quote="Trump's incitement of the invasion of the Capitol on January 6, 2021 removes my objection to the fascist label. His open encouragement of civic violence to overturn an election crosses a red line."
      attribution="Robert Paxton — Columbia University, World's Leading Fascism Expert · January 11, 2021 · Leading fascism scholar who resisted the term finally applied it after January 6"
    />
  </VoicesSection>

  <!-- 2020 Bottom Line -->
  <ColoredSection background="#120a0a" borderColor="var(--red)">
    <AlertBanner icon="🔴" title="The 2020 Bottom Line" variant="red">
      <p style="font-size: 16px; color: var(--muted); line-height: 1.7;"><strong style="color: var(--text);">Trump attempted a coup.</strong> When the voters rejected him, when state officials refused to change results, when courts threw out his cases, when his own Vice President refused to go along — Trump incited a violent mob to attack the Capitol to stop the peaceful transfer of power.</p>
      <p style="font-size: 16px; color: var(--muted); line-height: 1.7; margin-top: 12px;">He has been criminally indicted for these actions. The evidence is overwhelming. This is not opinion — this is documented fact.</p>
    </AlertBanner>
  </ColoredSection>

  <!-- ===== 2024: UNRESOLVED QUESTIONS ===== -->
  <SectionDivider label="2024" />
  <SectionHeader
    eyebrow="Unresolved Questions"
    title="2024: No<br>Accountability"
    introText="Trump never accepted accountability for 2020. He continued pre-emptive fraud claims throughout 2024 campaign, won the election, and immediately stopped claiming fraud. The pattern revealed: Elections are only 'rigged' when he loses. The lack of accountability for 2020 enabled 2026 escalation."
  />

  <!-- What Trump Said - 2024 -->
  <VoicesSection
    eyebrow="2024 · What Trump Said"
    title="Pre-Emptive<br>Fraud Claims"
    introText="Trump's pre-emptive fraud claims during 2024 campaign"
  >
    <VoiceCard
      quote="Christians, get out and vote, just this time. You won't have to do it anymore. Four more years, you know what? It'll be fixed. It'll be fine. You won't have to vote anymore, my beautiful Christians."
      attribution="Donald Trump — July 26, 2024 · Told Christians they &quot;won't have to vote anymore&quot; after this election. Suggested elections would be &quot;fixed&quot; after he wins. · <a href='https://www.cbsnews.com/news/donald-trump-christian-voters-turning-point-action/' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: CBS News</a>"
    />
    <VoiceCard
      quote="If I lose, I will tell you what. It's possible because they cheat. That's the only way we're going to lose, because they cheat."
      attribution="Donald Trump — September 27, 2024 · Pre-emptive claims that any loss would be due to cheating. · <a href='https://transcripts.cnn.com/show/sotu/date/2024-09-29/segment/01' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: CNN transcript</a>"
    />
    <VoiceCard
      quote="Because they cheat, that's the only way we're going to lose because they cheat."
      attribution="Donald Trump — November 1, 2024 · Repeated pre-emptive fraud claims days before election. Pattern: if he loses, it's &quot;rigged.&quot; · <a href='https://transcripts.cnn.com/show/cnr/date/2024-11-01/segment/26' target='_blank' rel='noreferrer' style='color: var(--red);'>Source: CNN transcript</a>"
    />
    <VoiceCard
      quote="A Massive Fraud of this type and magnitude allows for the termination of all rules, regulations, and articles, even those found in the Constitution."
      attribution="Donald Trump — December 2022 · Trump explicitly called for terminating the Constitution to overturn the 2020 election he lost. · Source: Truth Social post"
    />
  </VoicesSection>

  <!-- What Trump Did - 2024 -->
  <TimelineSection title="What Trump<br>Did" subtitle="2024 campaign actions">
    <TimelineItem
      date="THROUGHOUT 2024"
      title="Systematic Pre-Emptive Fraud Claims"
      description="Trump repeatedly claimed: 'If I lose, it was rigged.' 'The only way we lose is if they cheat.' 'They're already cheating in Pennsylvania.' Claimed mail-in ballots were fraudulent (despite no evidence). Result: Trump won the 2024 election and these claims immediately stopped. Pattern revealed: Elections are only 'rigged' when he loses."
    />
    <TimelineItem
      date="NOV 2024"
      title="Won 2024 Election, Fraud Claims Stopped"
      description="Trump won 2024 presidential election. All fraud claims immediately ceased. No complaints about mail-in ballots, voting machines, or fraud. This reveals the pattern: Trump only claims fraud when he loses. When he wins, suddenly the same systems he called 'rigged' are perfectly legitimate."
    />
    <TimelineItem
      date="2022-2024"
      title="No Accountability for 2020 Coup Attempt"
      description="Despite criminal indictments, Trump never accepted responsibility for January 6. Continued to claim 2020 was 'stolen.' Praised January 6 rioters as 'patriots.' Promised to pardon them if re-elected. Faced no electoral consequences (won 2024). Consequence: Lack of accountability emboldened Trump to escalate election rigging attempts in 2026."
    />
  </TimelineSection>

  <!-- Legal Response - 2024 -->
  <TimelineSection title="Legal<br>Response" subtitle="2024 accountability failures">
    <TimelineItem
      date="2024"
      title="Criminal Cases Delayed"
      description="Federal and state criminal cases for 2020 election interference were significantly delayed. Jack Smith federal case: Delayed by Trump's immunity appeals. Georgia RICO case: Delayed by procedural challenges. No trials before 2024 election. Result: Trump won election before facing trial, then used presidential power to dismiss federal cases."
    />
    <TimelineItem
      date="JUL 2024"
      badge="SCOTUS"
      badgeType="serious"
      title="Supreme Court Grants Broad Presidential Immunity"
      description="Supreme Court ruled presidents have immunity for 'official acts' in Trump v. United States. Impact: Significantly complicated prosecutions of Trump for acts taken while president, including January 6. Consequence: Emboldened Trump by shielding presidential actions from accountability."
    />
  </TimelineSection>

  <!-- Expert Assessment - 2024 -->
  <VoicesSection
    eyebrow="2024 · Expert Assessment"
    title="Expert<br>Warnings"
    introText="What experts warned about during 2024"
  >
    <VoiceCard
      quote="The pre-announcement that an election will be fraudulent if you lose is a classic authoritarian tactic. It's the big lie in advance. If there are no consequences for January 6, it will happen again, but worse."
      attribution="Timothy Snyder — Yale Historian, Author of &quot;On Tyranny&quot; · October 2024 · Source: The Atlantic"
    />
    <VoiceCard
      quote="Trump is telling us exactly what he plans to do: eliminate the need for future elections. When an authoritarian tells you their plans, believe them."
      attribution="Ruth Ben-Ghiat — NYU Historian, Expert on Authoritarianism · July 2024 (responding to &quot;won't have to vote anymore&quot; comment) · Source: MSNBC"
    />
    <VoiceCard
      quote="The Supreme Court's immunity decision gives Trump a road map to authoritarianism. Combined with lack of accountability for January 6, we're in unprecedented danger."
      attribution="Laurence Tribe — Harvard Law Professor · July 2024"
    />
  </VoicesSection>

  <!-- 2024 Pattern -->
  <ColoredSection background="#1a1200" borderColor="var(--amber)">
    <AlertBanner icon="⚠️" title="The 2024 Pattern" variant="amber">
      <p style="font-size: 16px; color: var(--muted); line-height: 1.7;">Trump spent 2024 pre-emptively claiming fraud if he lost. When he won, fraud claims stopped. The pattern is unmistakable: <strong style="color: var(--text);">Trump believes elections are legitimate only when he wins.</strong></p>
      <p style="font-size: 16px; color: var(--muted); line-height: 1.7; margin-top: 12px;">More critically: <strong style="color: var(--text);">The lack of accountability for the 2020 coup attempt emboldened Trump to escalate his election rigging tactics in 2026.</strong> Without consequences, authoritarians escalate.</p>
    </AlertBanner>
  </ColoredSection>

  <!-- Related: Path to Fascism -->
  <ColoredSection background="#0a0a14" borderColor="var(--blue)">
    <AlertBanner icon="🔗" title="Related: Path to Fascism" variant="blue">
      <p style="font-size: 15px; color: var(--muted); line-height: 1.7; margin-bottom: 12px;">Experts like Timothy Snyder and Ruth Ben-Ghiat are warning about Trump's election rigging as a <strong style="color: var(--text);">classic authoritarian tactic</strong>. This is a pattern documented across fascist movements throughout history.</p>
      <ul style="margin-left: 1.2rem; margin-bottom: 12px;">
        <li><strong style="color: var(--text);">Fraudulent Elections</strong> — One of Lawrence Britt's 14 characteristics of fascism</li>
        <li><strong style="color: var(--text);">Undermining Democratic Norms</strong> — Central to all scholarly definitions of fascism</li>
        <li><strong style="color: var(--text);">Pre-emptive Fraud Claims</strong> — "The big lie in advance" (Timothy Snyder)</li>
        <li><strong style="color: var(--text);">No Consequences = Escalation</strong> — Authoritarian consolidation pattern</li>
      </ul>
      <p style="margin: 0;"><a href="/fascism" style="color: var(--red-bright); text-decoration: underline; font-weight: 600;">Read Full Analysis: Path to Fascism</a></p>
    </AlertBanner>
  </ColoredSection>

  <!-- ===== 2026: ACTIVE RIGGING ===== -->
  <SectionDivider label="2026" />
  <SectionHeader
    eyebrow="Active Rigging · Happening Now"
    title="2026: Rigging<br>Before the Vote"
    introText="This is happening right now. Unlike 2020 (attempting to overturn after losing), Trump is attempting to rig the 2026 midterms before votes are even cast. This is documented, real-time election rigging through federal law enforcement, unconstitutional takeover attempts, and systematic dismantling of oversight."
    eyebrowColor="var(--red-bright)"
  />

  <HighlightBar text="THESE ACTIONS ARE HAPPENING RIGHT NOW" variant="red" />

  <!-- What Trump Said - 2026 -->
  <VoicesSection
    eyebrow="2026 · What Trump Said"
    title="Stated<br>Intentions"
    introText="Trump's stated intentions for 2026 elections"
  >
    <VoiceCard
      quote="We should take over the voting in at least — many, 15 places. The Republicans ought to nationalize the voting."
      attribution="Donald Trump — February 2, 2026 (Dan Bongino Show) · Called for Republicans to &quot;nationalize voting&quot; and federally take over elections in 15 states. Named Detroit, Philadelphia, and Atlanta as &quot;extremely corrupt&quot; (all Democratic-leaning cities, no evidence). Constitutional violation: Article 1, Section 4 grants states, not the federal government, power over elections. · <a href='https://www.washingtonpost.com/politics/2026/02/02/trump-elections-nationalize-fraud/' target='_blank' rel='noreferrer' style='color: var(--red);'>Washington Post</a> | <a href='https://www.independent.co.uk/news/world/americas/us-politics/trump-midterm-election-results-voting-nationalize-b2914259.html' target='_blank' rel='noreferrer' style='color: var(--red);'>The Independent</a>"
    />
